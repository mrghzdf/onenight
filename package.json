{
  "name": "onenight-ptbr",
  "version": "2.1.2",
  "private": true,
  "main": "index.js",
  "scripts": {
    "gen:tracks": "node scripts/generate-audio-tracks.js",
    "prestart": "npm run gen:tracks",
    "preandroid": "npm run gen:tracks",
    "preios": "npm run gen:tracks",
    "preweb": "npm run gen:tracks",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "eas build -p android --profile preview",
    "build:apk:local": "eas build --platform android --profile preview --local --output ./one-night-ptbr.apk",
    "build:apk:debug-local": "NODE_ENV=production npx expo prebuild -p android --no-install && cd android && NODE_ENV=production ./gradlew assembleDebug && cd .. && cp ./android/app/build/outputs/apk/debug/app-debug.apk ./one-night-ptbr-debug.apk",
    "build:apk:release-install": "./scripts/build-install-release.sh",
    "build:aab": "eas build -p android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.24.0",
    "expo": "^52.0.49",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-font": "~13.0.4",
    "expo-localization": "~16.0.1",
    "expo-speech": "~13.0.1",
    "expo-splash-screen": "^0.29.24",
    "expo-status-bar": "~2.0.0",
    "react": "^18.3.1",
    "react-native": "^0.76.9",
    "react-native-safe-area-context": "4.12.0"
  },
  "devDependencies": {
    "eas-cli": "^16.32.0"
  }
}
